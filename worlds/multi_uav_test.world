<?xml version="1.0" ?>
<sdf version="1.9">
  <!-- Multi-UAV Test World - 多无人机集群测试场景 -->
  <!-- 棉花种植无人机智巡仿真系统 -->
  <world name="multi_uav_test_world">

    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <scene>
      <ambient>0.5 0.5 0.5 1</ambient>
      <background>0.8 0.9 1.0 1</background>
      <shadows>true</shadows>
      <grid>on</grid>
    </scene>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>50 0 100 0 0 0</pose>
      <diffuse>0.8 0.8 0.7 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- 平坦测试场地 -->
    <model name="test_ground">
      <static>true</static>
      <link name="ground_link">
        <collision name="ground_collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>200 200</size>
            </plane>
          </geometry>
        </collision>
        <visual name="ground_visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>200 200</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.3 0.3 0.3 1</ambient>
            <diffuse>0.35 0.35 0.35 1</diffuse>
            <specular>0.0 0.0 0.0 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- 网格参考标记 -->
    <model name="grid_markers">
      <static>true</static>
      <link name="link">
        <!-- 2m间隔网格标记 -->
        <visual name="marker_0_0">
          <geometry><box><size>0.2 0.2 0.02</size></box></geometry>
          <material><ambient>1 0 0 1</ambient><diffuse>1 0 0 1</diffuse></material>
          <pose>0 0 0.01 0 0 0</pose>
        </visual>
        <visual name="marker_10_0">
          <geometry><box><size>0.2 0.2 0.02</size></box></geometry>
          <material><ambient>0 1 0 1</ambient><diffuse>0 1 0 1</diffuse></material>
          <pose>10 0 0.01 0 0 0</pose>
        </visual>
        <visual name="marker_0_10">
          <geometry><box><size>0.2 0.2 0.02</size></box></geometry>
          <material><ambient>0 0 1 1</ambient><diffuse>0 0 1 1</diffuse></material>
          <pose>0 10 0.01 0 0 0</pose>
        </visual>
        <visual name="marker_20_20">
          <geometry><box><size>0.2 0.2 0.02</size></box></geometry>
          <material><ambient>1 1 0 1</ambient><diffuse>1 1 0 1</diffuse></material>
          <pose>20 20 0.01 0 0 0</pose>
        </visual>
      </link>
    </model>

    <!-- 测试障碍物 -->
    <model name="obstacle_1">
      <static>true</static>
      <pose>8 5 0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><cylinder><radius>0.3</radius><length>3</length></cylinder></geometry>
        </collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.3</radius><length>3</length></cylinder></geometry>
          <material><ambient>0.8 0.2 0.2 1</ambient><diffuse>0.9 0.3 0.3 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="obstacle_2">
      <static>true</static>
      <pose>-5 8 0 0 0 0</pose>
      <link name="link">
        <collision name="col">
          <geometry><box><size>1 1 4</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>1 1 4</size></box></geometry>
          <material><ambient>0.2 0.2 0.8 1</ambient><diffuse>0.3 0.3 0.9 1</diffuse></material>
        </visual>
      </link>
    </model>

    <gui fullscreen='0'>
      <camera name='user_camera'>
        <pose>-30 -30 40 0 0.5 0.8</pose>
        <view_controller>orbit</view_controller>
      </camera>
    </gui>

    <plugin name="gazebo_ros_factory" filename="libgazebo_ros_factory.so"/>
    <plugin name="gazebo_ros_state" filename="libgazebo_ros_state.so"/>

  </world>
</sdf>
